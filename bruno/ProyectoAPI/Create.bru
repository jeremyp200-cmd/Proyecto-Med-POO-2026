post {
  url: http://localhost:5186/api/medicamentos
  body: json
  auth: inherit
}

body:json {
  {
    "nombre": "Ibuprofeno",
    "cantidad": 20,
    "tipo": "Normal"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

docs {
  Registra un nuevo medicamento en el sistema (Base de Datos).
  
  Permisos: Solo Doctor.
  Respuestas:
  
  200 OK: Medicamento creado con exito.
  
  403 Forbidden: Si un Enfermero intenta crearlo.
}
